package project;

public class CarroDePasseio extends MeiosDeTransporte{
	
	CarroDePasseio(String marca, String modelo, String cor, String placa){
		super.marca = marca;
		super.modelo = modelo;
		super.cor = cor;
		super.placa = placa;
	}
	
	@Override
	public String toString() {
		String text = "";
		text += "Tipo: Carro de passeio\n";
		text += "Placa:" + super.placa + "\n";
		text += "Modelo:" + super.modelo + "\n";
		text += "Marca:" + super.marca + "\n";
		text += "Cor:" + super.Cor;
		
		return text;
	}
}
